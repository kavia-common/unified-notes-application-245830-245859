# Public env vars used by the frontend (Next.js)
# Copy to .env.local for local development.
#
# Required: base URL of the backend REST API (preferred).
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Optional fallback: some deployments may provide BACKEND_URL instead of API_BASE.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Optional: used for future websocket features (not required for core CRUD flows).
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Optional: where the frontend is hosted (used in some redirect flows if needed).
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
