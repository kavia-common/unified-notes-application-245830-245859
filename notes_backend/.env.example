# notes_backend environment variables
# Ask the orchestrator to set these in the real .env for your environment.

# Required: Postgres connection string (same as notes_db)
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/notes

# Required: used to sign/verify bearer tokens (keep secret in production)
AUTH_TOKEN_SECRET=dev_only_change_me

# Optional: token expiration in hours
AUTH_TOKEN_TTL_HOURS=168

# Optional: CORS allowed origins (comma-separated). For local dev:
CORS_ORIGINS=http://localhost:3000
